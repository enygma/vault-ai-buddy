{
  "name": "vault-ai-chat",
  "version": "0.1.0",
  "description": "Chat with an AI inside Obsidian with vault-aware context and guarded file actions.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src",
    "version": "node version-bump.mjs && git add -A manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ai",
    "chat",
    "vault"
  ],
  "author": "Chris Cornutt",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2"
  }
}
